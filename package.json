{
  "name": "@moleculer/database",
  "version": "0.4.0",
  "description": "Advanced Database Access Service for Moleculer microservices framework",
  "main": "index.js",
  "typings": "index.d.ts",
  "scripts": {
    "dev": "nodemon examples/index.js",
    "ci:unit": "jest --testMatch \"**/unit/**/*.spec.js\" --watch",
    "ci:integration": "jest --testMatch \"**/integration/**/*.spec.js\" --runInBand --watch",
    "ci:leak": "jest --testMatch \"**/leak-detection/**/index.spec.js\" --runInBand --watch",
    "test:unit": "jest --testMatch \"**/unit/**/*.spec.js\"",
    "test:integration": "jest --testMatch \"**/integration/**/*.spec.js\" --runInBand --coverage",
    "test:leak": "jest --testMatch \"**/leak-detection/**/*.spec.js\" --runInBand",
    "test": "jest --testMatch \"**/*.spec.js\" --runInBand --coverage",
    "lint": "eslint src examples test",
    "bench": "node benchmark/index.js",
    "bench:watch": "nodemon benchmark/index.js",
    "deps": "npm-check -u && npm audit fix",
    "ci-update-deps": "ncu -u --target minor",
    "typecheck": "tsc --project tsconfig.json",
    "test:ts": "tsc --project test/typescript/tsconfig.json",
    "release": "npm publish --access public && git push --tags"
  },
  "keywords": [
    "moleculer",
    "microservice"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/moleculerjs/database.git"
  },
  "author": "MoleculerJS",
  "license": "MIT",
  "peerDependencies": {
    "moleculer": "^0.14.12 || ^0.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@seald-io/nedb": "^4.1.2",
    "@vscode/sqlite3": "^5.1.12-vscode",
    "axios": "^1.14.0",
    "benchmarkify": "^4.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-security": "^4.0.0",
    "fakerator": "^0.3.6",
    "globals": "^17.4.0",
    "globby": "^13.2.2",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "kleur": "^4.1.5",
    "knex": "^3.2.7",
    "moleculer": "github:moleculerjs/moleculer#next",
    "moleculer-repl": "^0.7.4",
    "moleculer-web": "github:moleculerjs/moleculer-web#next",
    "mongodb": "^6.21.0",
    "mysql": "^2.18.1",
    "mysql2": "^3.20.0",
    "nodemon": "^3.1.14",
    "npm-check-updates": "^19.6.6",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "qs": "^6.15.0",
    "sequelize": "^6.37.8",
    "tedious": "^19.2.1",
    "typescript": "^6.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "rootDir": "./src",
    "roots": [
      "../test"
    ],
    "coverageDirectory": "../coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/services/"
    ]
  },
  "engines": {
    "node": ">= 22.x.x"
  },
  "dependencies": {
    "fastest-validator": "^1.19.1",
    "lodash": "^4.17.23",
    "semver": "^7.7.4",
    "sqlite3": "^6.0.1"
  }
}
